---
// Real Halifax SRTM elevation data rendered as animated topo contour lines.
// Data: public/data/halifax-elevation.json (60×38 grid, 44.52–44.80°N)
// Mouse: hovering raises a peak in the terrain under the cursor.
---

<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <canvas id="topo-canvas" class="absolute inset-0 w-full h-full"></canvas>
  <!-- Radial gradient overlay — fades edges to background colour -->
  <div class="absolute inset-0 bg-radial-fade"></div>
</div>

<style>
  .bg-radial-fade {
    background: radial-gradient(ellipse at center, transparent 25%, #1a1a2e 85%);
  }
</style>

<script>
(async () => {
  const canvas = document.getElementById('topo-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  // ── Load elevation data ──────────────────────────────────
  let elevGrid: number[][] = [];
  let GRID_W = 30, GRID_H = 20;

  try {
    const res = await fetch('/data/halifax-elevation.json');
    const json = await res.json();
    GRID_W = json.grid_w;
    GRID_H = json.grid_h;
    const flat: number[] = json.elevation;
    for (let r = 0; r < GRID_H; r++) {
      elevGrid[r] = flat.slice(r * GRID_W, (r + 1) * GRID_W);
    }
  } catch {
    // Fallback: simple noise grid so the page never breaks
    for (let r = 0; r < GRID_H; r++) {
      elevGrid[r] = [];
      for (let c = 0; c < GRID_W; c++) {
        elevGrid[r][c] =
          Math.sin(c / GRID_W * 6 + r / GRID_H * 4) * 0.5 +
          Math.cos(c / GRID_W * 3 - r / GRID_H * 7) * 0.5;
      }
    }
  }

  // ── Mouse tracking (on parent section) ──────────────────
  let tmx = -999, tmy = -999;   // target (raw)
  let  mx = -999,  my = -999;   // smoothed

  const hero = canvas.closest('section');
  if (hero) {
    hero.addEventListener('mousemove', (e: Event) => {
      const ev = e as MouseEvent;
      const r = (hero as HTMLElement).getBoundingClientRect();
      tmx = ev.clientX - r.left;
      tmy = ev.clientY - r.top;
    });
    hero.addEventListener('mouseleave', () => { tmx = -999; tmy = -999; });
  }

  // ── Bilinear sample with tiny ambient drift ─────────────
  let t = 0;
  function sampleElev(fc: number, fr: number): number {
    const drift = 0.014;
    const wc = fc + (Math.sin(fc * 0.9 + fr * 1.1 + t * 0.4) +
                     Math.cos(fc * 1.8 - fr * 0.7 + t * 0.28) * 0.5) * drift;
    const wr = fr + (Math.cos(fc * 0.7 + fr * 1.2 - t * 0.36) +
                     Math.sin(fc * 1.5 + fr * 0.9 + t * 0.20) * 0.5) * drift;

    const c0 = Math.max(0, Math.min(GRID_W - 2, Math.floor(wc)));
    const r0 = Math.max(0, Math.min(GRID_H - 2, Math.floor(wr)));
    const tx = wc - c0, ty = wr - r0;

    return elevGrid[r0    ][c0    ] * (1 - tx) * (1 - ty)
         + elevGrid[r0    ][c0 + 1] *      tx  * (1 - ty)
         + elevGrid[r0 + 1][c0    ] * (1 - tx) *      ty
         + elevGrid[r0 + 1][c0 + 1] *      tx  *      ty;
  }

  // ── Marching squares ────────────────────────────────────
  function march(
    grid: number[][], cols: number, rows: number,
    cw: number, ch: number, level: number
  ) {
    const lerp = (a: number, b: number, v: number) => (v - a) / (b - a);
    ctx.beginPath();
    for (let r = 0; r < rows - 1; r++) {
      for (let c = 0; c < cols - 1; c++) {
        const tl = grid[r    ][c    ], tr = grid[r    ][c + 1];
        const bl = grid[r + 1][c    ], br = grid[r + 1][c + 1];
        const x0 = c * cw, y0 = r * ch, x1 = x0 + cw, y1 = y0 + ch;
        const idx = (tl > level ? 8 : 0) | (tr > level ? 4 : 0)
                  | (br > level ? 2 : 0) | (bl > level ? 1 : 0);
        if (!idx || idx === 15) continue;
        const tp = lerp(tl, tr, level), rp = lerp(tr, br, level);
        const bp = lerp(bl, br, level), lp = lerp(tl, bl, level);
        const p: Record<string, [number, number]> = {
          T: [x0 + tp * cw, y0], R: [x1, y0 + rp * ch],
          B: [x0 + bp * cw, y1], L: [x0, y0 + lp * ch],
        };
        const segs: Record<number, [string, string][]> = {
          1:[['L','B']], 2:[['B','R']], 3:[['L','R']], 4:[['T','R']],
          5:[['T','L'],['B','R']], 6:[['T','B']], 7:[['T','L']],
          8:[['T','L']], 9:[['T','B']], 10:[['T','R'],['L','B']],
          11:[['T','R']], 12:[['L','R']], 13:[['B','R']], 14:[['L','B']],
        };
        (segs[idx] ?? []).forEach(([a, b]) => {
          ctx.moveTo(p[a][0], p[a][1]);
          ctx.lineTo(p[b][0], p[b][1]);
        });
      }
    }
    ctx.stroke();
  }

  // ── Render constants ────────────────────────────────────
  const RC = 200, RR = 125;  // render grid resolution
  const N_CONTOURS = 20;

  // ── Main loop ───────────────────────────────────────────
  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    if (canvas.width !== W || canvas.height !== H) {
      canvas.width = W; canvas.height = H;
    }

    // Smooth mouse follow
    if (tmx < 0) {
      mx += (-999 - mx) * 0.06;
      my += (-999 - my) * 0.06;
    } else {
      mx += (tmx - mx) * 0.09;
      my += (tmy - my) * 0.09;
    }

    ctx.clearRect(0, 0, W, H);

    const cw = W / (RC - 1), ch = H / (RR - 1);

    // Build render grid
    const grid: number[][] = [];
    for (let r = 0; r < RR; r++) {
      grid[r] = [];
      for (let c = 0; c < RC; c++) {
        const fc = (c / (RC - 1)) * (GRID_W - 1);
        const fr = (r / (RR - 1)) * (GRID_H - 1);
        let v = sampleElev(fc, fr);

        // Raise a subtle peak under the cursor
        if (mx > 0) {
          const px = c * cw, py = r * ch;
          const dist = Math.sqrt((px - mx) ** 2 + (py - my) ** 2);
          const inf = Math.max(0, 1 - dist / (W * 0.06));
          v += inf * inf * 0.6;
        }

        grid[r][c] = v;
      }
    }

    // Coastline: single contour at -0.5 (midpoint between ocean=-1.0 and land≥0)
    // traces every ocean/land boundary as one clean line
    ctx.strokeStyle = 'rgba(76,175,130,0.55)';
    ctx.lineWidth   = 1.1;
    ctx.lineJoin    = 'round';
    ctx.lineCap     = 'round';
    march(grid, RC, RR, cw, ch, -0.5);

    // Land contours — range [0.02, 0.98] sits entirely over land values
    for (let i = 0; i <= N_CONTOURS; i++) {
      const level = 0.02 + (i / N_CONTOURS) * 0.96;
      const isIndex = i % 5 === 0;
      ctx.strokeStyle = `rgba(76,175,130,${isIndex ? 0.52 : 0.20})`;
      ctx.lineWidth   = isIndex ? 1.0 : 0.5;
      ctx.lineJoin    = 'round';
      ctx.lineCap     = 'round';
      march(grid, RC, RR, cw, ch, level);
    }

    t += 0.004;
    requestAnimationFrame(draw);
  }

  // ── Kick off ─────────────────────────────────────────────
  draw();
})();
</script>
