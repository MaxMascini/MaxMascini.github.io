---
// Animated topographic contour lines SVG background
---

<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <!-- Layer 1: large slow contours -->
  <svg
    class="absolute inset-0 w-full h-full animate-topo-drift"
    viewBox="0 0 1200 700"
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g stroke="#2C9AB7" stroke-width="0.8" opacity="0.22">
      <path d="M-100,200 C150,180 300,220 500,190 C700,160 850,210 1000,195 C1150,180 1250,200 1400,185"/>
      <path d="M-100,250 C120,230 280,265 480,240 C680,215 830,255 990,238 C1140,221 1240,245 1400,230"/>
      <path d="M-100,300 C130,285 290,310 490,290 C690,270 840,300 1000,285 C1160,270 1260,290 1400,278"/>
      <path d="M-100,350 C140,338 300,355 500,342 C700,329 850,348 1010,336 C1170,324 1270,340 1400,330"/>
      <path d="M-100,400 C150,390 310,405 510,395 C710,385 860,398 1020,388 C1180,378 1280,392 1400,383"/>
      <path d="M-100,450 C160,443 320,455 520,447 C720,439 870,450 1030,442 C1190,434 1290,446 1400,438"/>
      <path d="M-100,150 C160,135 320,158 520,142 C720,126 870,150 1030,138 C1190,126 1290,145 1400,132"/>
      <path d="M-100,100 C170,88 330,108 530,94 C730,80 880,102 1040,90 C1200,78 1300,95 1400,84"/>
    </g>
  </svg>

  <!-- Layer 2: tighter contours, different speed -->
  <svg
    class="absolute inset-0 w-full h-full animate-topo-drift-2"
    viewBox="0 0 1200 700"
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g stroke="#4caf82" stroke-width="0.5" opacity="0.12">
      <ellipse cx="300" cy="350" rx="280" ry="180" transform="rotate(-15 300 350)"/>
      <ellipse cx="300" cy="350" rx="240" ry="148" transform="rotate(-15 300 350)"/>
      <ellipse cx="300" cy="350" rx="200" ry="116" transform="rotate(-15 300 350)"/>
      <ellipse cx="300" cy="350" rx="160" ry="85" transform="rotate(-15 300 350)"/>
      <ellipse cx="300" cy="350" rx="120" ry="55" transform="rotate(-15 300 350)"/>
      <ellipse cx="900" cy="300" rx="220" ry="160" transform="rotate(10 900 300)"/>
      <ellipse cx="900" cy="300" rx="180" ry="125" transform="rotate(10 900 300)"/>
      <ellipse cx="900" cy="300" rx="140" ry="92" transform="rotate(10 900 300)"/>
      <ellipse cx="900" cy="300" rx="100" ry="62" transform="rotate(10 900 300)"/>
      <ellipse cx="650" cy="520" rx="190" ry="120" transform="rotate(-8 650 520)"/>
      <ellipse cx="650" cy="520" rx="150" ry="90" transform="rotate(-8 650 520)"/>
      <ellipse cx="650" cy="520" rx="110" ry="62" transform="rotate(-8 650 520)"/>
    </g>
  </svg>

  <!-- Layer 3: subtle diagonal lines -->
  <svg
    class="absolute inset-0 w-full h-full animate-topo-drift-3"
    viewBox="0 0 1200 700"
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g stroke="#2C9AB7" stroke-width="0.4" opacity="0.1">
      <path d="M0,600 C200,540 400,580 600,520 C800,460 1000,510 1200,470"/>
      <path d="M0,560 C200,505 400,542 600,485 C800,428 1000,474 1200,436"/>
      <path d="M0,520 C200,468 400,502 600,448 C800,394 1000,438 1200,402"/>
      <path d="M200,650 C350,620 500,640 650,615 C800,590 950,605 1100,580"/>
      <path d="M-50,480 C100,455 250,470 400,448 C550,426 700,440 850,420 C1000,400 1150,412 1300,394"/>
    </g>
  </svg>

  <!-- Radial gradient overlay to fade edges -->
  <div class="absolute inset-0 bg-radial-fade"></div>
</div>

<style>
  .bg-radial-fade {
    background: radial-gradient(ellipse at center, transparent 30%, #1a1a2e 100%);
  }
</style>
