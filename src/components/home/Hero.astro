---
import TopoBackground from './TopoBackground.astro';
import SocialLinks from '../ui/SocialLinks.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <TopoBackground />

  <!-- Subtle grid dot pattern -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle, #2C9AB7 1px, transparent 1px); background-size: 40px 40px;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 text-center max-w-4xl mx-auto px-6">
    <!-- Pre-title label -->
    <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full border border-teal/20 bg-teal/5 text-teal text-xs font-semibold tracking-[0.18em] uppercase animate-[fadeUp_0.5s_ease-out_0.1s_both]">
      <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse inline-block"></span>
      Halifax, NS · Dalhousie University
    </div>

    <!-- Name -->
    <h1 class="font-display font-light text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-text-primary leading-none tracking-tight mb-4 animate-[fadeUp_0.6s_ease-out_0.2s_both]">
      Max <span class="text-teal">Mascini</span>
    </h1>

    <!-- Typewriter subtitle -->
    <div class="h-8 mb-8 animate-[fadeUp_0.6s_ease-out_0.35s_both]">
      <p class="text-text-muted text-xl sm:text-2xl font-display">
        <span id="typewriter-text" class="text-teal-light"></span><span class="animate-blink text-teal-light">|</span>
      </p>
    </div>

    <!-- Tagline -->
    <p class="text-text-muted text-base sm:text-lg max-w-xl mx-auto leading-relaxed mb-10 animate-[fadeUp_0.6s_ease-out_0.45s_both]">
      Researching AI ethics & theory of mind. Exploring Newfoundland on foot.
      Writing about both.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10 animate-[fadeUp_0.6s_ease-out_0.55s_both]">
      <a
        href="/research"
        class="px-6 py-2.5 rounded-full bg-teal text-white font-semibold text-sm hover:bg-teal-light transition-all duration-200 hover:-translate-y-0.5 shadow-lg shadow-teal/25"
      >
        My Research
      </a>
      <a
        href="/projects"
        class="px-6 py-2.5 rounded-full border border-teal/40 text-teal font-semibold text-sm hover:bg-teal/10 hover:border-teal transition-all duration-200 hover:-translate-y-0.5"
      >
        View Projects
      </a>
    </div>

    <!-- Social links -->
    <div class="flex justify-center animate-[fadeUp_0.6s_ease-out_0.65s_both]">
      <SocialLinks />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-text-muted animate-[fadeUp_0.6s_ease-out_0.8s_both]">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-text-muted to-transparent"></div>
  </div>
</section>

<script>
  const phrases = ['CS Researcher', 'Backpacker', 'Neuroscience Alum', 'Data Viz Nerd'];
  const el = document.getElementById('typewriter-text');
  if (!el) throw new Error('typewriter-text not found');

  let phraseIdx = 0;
  let charIdx = 0;
  let deleting = false;
  let pauseFrames = 0;

  function tick() {
    const phrase = phrases[phraseIdx % phrases.length];

    if (!deleting) {
      el.textContent = phrase.slice(0, ++charIdx);
      if (charIdx === phrase.length) {
        deleting = true;
        pauseFrames = 50;
      }
    } else {
      if (pauseFrames > 0) {
        pauseFrames--;
      } else {
        el.textContent = phrase.slice(0, --charIdx);
        if (charIdx === 0) {
          deleting = false;
          phraseIdx++;
          pauseFrames = 8;
        }
      }
    }

    setTimeout(tick, deleting && pauseFrames === 0 ? 45 : 80);
  }

  setTimeout(tick, 800);
</script>
