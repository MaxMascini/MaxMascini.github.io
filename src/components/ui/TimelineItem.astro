---
interface Props {
  year: string;
  title: string;
  subtitle?: string;
  description?: string;
  tag?: string;
  isLast?: boolean;
}

const { year, title, subtitle, description, tag, isLast = false } = Astro.props;
---

<div class="reveal flex gap-6 relative">
  <!-- Left: year + line -->
  <div class="flex flex-col items-center shrink-0 w-16">
    <span class="text-teal font-display font-semibold text-sm tabular-nums">{year}</span>
    <div class="w-px flex-1 mt-2 bg-gradient-to-b from-teal/40 to-transparent" class:list={[{ 'opacity-0': isLast }]}></div>
  </div>

  <!-- Right: content -->
  <div class={`pb-${isLast ? '0' : '10'} flex-1`}>
    <div class="flex items-start gap-3 flex-wrap">
      <h3 class="font-display font-semibold text-text-primary text-base leading-snug">{title}</h3>
      {tag && (
        <span class="tag-pill bg-teal/15 text-teal border border-teal/20 text-[9px] mt-0.5">{tag}</span>
      )}
    </div>
    {subtitle && (
      <p class="text-text-muted text-sm mt-0.5">{subtitle}</p>
    )}
    {description && (
      <p class="text-text-muted text-sm mt-2 leading-relaxed">{description}</p>
    )}
  </div>
</div>
