---
import TagBadge from './TagBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, categories, image, imageAlt } = post.data;

const formattedDate = new Date(date).toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${post.slug}`}
  class="group flex flex-col bg-surface border border-surface2 rounded-xl overflow-hidden card-hover"
  data-categories={categories.join(',')}
>
  {image && (
    <div class="overflow-hidden aspect-video">
      <img
        src={image}
        alt={imageAlt ?? title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>
  )}

  <div class="flex flex-col flex-1 p-5">
    <div class="flex flex-wrap gap-1.5 mb-3">
      {categories.map((cat) => <TagBadge label={cat} />)}
    </div>

    <h2 class="font-display font-semibold text-lg text-text-primary group-hover:text-teal transition-colors leading-snug mb-2">
      {title}
    </h2>

    <p class="text-text-muted text-sm leading-relaxed flex-1 mb-4 line-clamp-3">
      {description}
    </p>

    <div class="flex items-center justify-between mt-auto">
      <time class="text-xs text-text-muted" datetime={new Date(date).toISOString()}>
        {formattedDate}
      </time>
      <span class="text-teal text-sm opacity-0 group-hover:opacity-100 transition-opacity translate-x-0 group-hover:translate-x-1 transition-transform">
        Read →
      </span>
    </div>
  </div>
</a>
